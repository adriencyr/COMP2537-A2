<!DOCTYPE html>
<html>
    <head>
        <title>Admin Page</title>
    </head>

    <body>
        <h1>Admin</h1>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>User Type</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                <% for (const user of users) { %>
                    <%- include("templates/user", { user: user }) %>
                <% } %>
            </tbody>
        </table>
    </body>

    <script src="script.js"></script>
</html>